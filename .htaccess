Options -Indexes

# Deny direct access to sensitive files
<FilesMatch "^(config|includes)">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|md|log|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP settings
php_flag display_errors Off
php_value session.cookie_httponly 1
php_value session.use_strict_mode 1
